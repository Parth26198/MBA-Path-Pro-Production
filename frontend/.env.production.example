# MBA Path Pro — Production Frontend Build
# Copy to frontend/.env.production before `npm run build`
#
# Same-origin API (recommended): Nginx proxies /api/v1 → backend
# Upload URLs resolve as /uploads/... on the same domain.

VITE_API_URL=/api/v1

# Alternative — separate API subdomain (not recommended unless CORS updated):
# VITE_API_URL=https://api.MY_DOMAIN/api/v1
