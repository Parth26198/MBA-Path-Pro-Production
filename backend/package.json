{
  "name": "mba-admission-backend",
  "version": "2.0.0",
  "description": "MBA Admission Management SaaS - API Server",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:migrate": "node src/database/migrate.js",
    "db:migrate:prod": "node src/database/runMigrations.js",
    "db:seed": "node src/database/seed.js",
    "db:setup": "node src/database/migrate.js && node src/database/runMigrations.js && node src/database/seed.js",
    "test": "node --test tests/"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.3",
    "nodemailer": "^6.9.15",
    "razorpay": "^2.9.4",
    "uuid": "^10.0.0",
    "winston": "^3.14.2"
  }
}
