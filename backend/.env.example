NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=mba_admission_db

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Razorpay (set RAZORPAY_ENABLED=true in production)
RAZORPAY_ENABLED=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Email (set EMAIL_ENABLED=true in production)
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=MBA Path Pro <noreply@mbapathpro.com>

# Frontend URL (CORS + email links including password reset)
CLIENT_URL=http://localhost:5173

# AWS S3 (optional — swap local uploads)
AWS_S3_ENABLED=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=mba-admission-uploads
