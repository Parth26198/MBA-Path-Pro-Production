# MBA Path Pro — Production Backend Environment
# Copy to backend/.env on the VPS and replace all placeholders.

NODE_ENV=production
PORT=5000
API_PREFIX=/api/v1

# MySQL — use a dedicated app user, not root (minimum 32 chars for password)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=mbapathpro
DB_PASSWORD=your_super_secure_password_minimum_32_characters_here
DB_NAME=mba_admission_db

# JWT — generate: openssl rand -base64 48 (must be ≥32 chars, no "change" placeholder)
JWT_SECRET=your_jwt_secret_minimum_32_characters_generated_securely_here
JWT_EXPIRES_IN=7d

# Uploads (relative to backend/ directory)
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Frontend origin for CORS and email links (MUST use HTTPS in production)
CLIENT_URL=https://yourdomain.com

# Razorpay (live payments)
RAZORPAY_ENABLED=true
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Email (password reset, notifications)
EMAIL_ENABLED=true
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_smtp_password_here
EMAIL_FROM=MBA Path Pro <noreply@yourdomain.com>

# Optional: S3 for distributed uploads (multi-instance scaling)
AWS_S3_ENABLED=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=mba-admission-uploads
